{
  "name": "sparrowword-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "concurrently -k -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "npm run dev --workspace @sparrowword/web",
    "dev:api": "npm run dev --workspace @sparrowword/dict-api",
    "start:web": "npm run start --workspace @sparrowword/web",
    "start:api": "npm run start --workspace @sparrowword/dict-api",
    "build:web": "npm run build --workspace @sparrowword/web",
    "build:api": "npm run build --workspace @sparrowword/dict-api",
    "build": "npm run build:web && npm run build:api",
    "typecheck": "npm run typecheck --workspace @sparrowword/web && npm run typecheck --workspace @sparrowword/dict-api",
    "test:web": "npm run test --workspace @sparrowword/web",
    "check": "npm run test:web && npm run typecheck && npm run build",
    "smoke:web": "npm run smoke --workspace @sparrowword/web",
    "worklog": "node ./scripts/worklog.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
