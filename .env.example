# SparrowWord local / server environment template
#
# Copy to .env on the machine that runs the services. Do not commit real .env files.

# Web -> dict-api URL used by Next.js server-side requests.
SPARROWWORD_DICT_API_BASE_URL=http://127.0.0.1:3001

# Browser-visible dict-api URL. In production this should usually be same-origin
# through a reverse proxy, for example https://sparrowword.example.com/api/dict.
NEXT_PUBLIC_SPARROWWORD_DICT_API_BASE_URL=http://127.0.0.1:3001

# dict-api network binding.
HOST=127.0.0.1
PORT=3001

# Restrict CORS in production. Use * only for local development.
SPARROWWORD_CORS_ORIGIN=http://127.0.0.1:3000

# User activity / workspace state SQLite file.
SPARROWWORD_ACTIVITY_DB=./services/dict-api/data/workspace-state.sqlite

# Offline dictionary resource directory, or set individual DB variables below.
SPARROWWORD_OFFLINE_RESOURCES_DIR=/opt/sparrowword/offline-resources
SPARROWWORD_ECDICT_DB=/opt/sparrowword/offline-resources/ecdict/stardict.db
SPARROWWORD_CEDICT_DB=/opt/sparrowword/offline-resources/cedict/cedict.sqlite
SPARROWWORD_OEWN_DB=/opt/sparrowword/offline-resources/oewn/oewn.sqlite
SPARROWWORD_TATOEBA_DB=/opt/sparrowword/offline-resources/tatoeba/tatoeba.sqlite

# Production readiness. Use all once the server has every dictionary resource.
SPARROWWORD_REQUIRED_DICTIONARIES=ecdict,cedict,oewn,tatoeba
SPARROWWORD_FAIL_ON_MISSING_DICTIONARIES=true
